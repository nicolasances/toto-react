{
  "name": "toto-react",
  "version": "0.1.0",
  "description": "Shared React component library for the Toto PWA ecosystem",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./server/stt": {
      "types": "./dist/server/stt/route.d.ts",
      "import": "./dist/server/stt/route.mjs",
      "require": "./dist/server/stt/route.js"
    },
    "./server/tts/synthesize": {
      "types": "./dist/server/tts/synthesize/route.d.ts",
      "import": "./dist/server/tts/synthesize/route.mjs",
      "require": "./dist/server/tts/synthesize/route.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "moment": "^2.30.1",
    "universal-cookie": "^7.2.2"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "next": "16.1.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}
